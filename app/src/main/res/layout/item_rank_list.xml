<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_stat_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:layout_marginBottom="6dp"
    android:paddingStart="12dp"
    android:paddingTop="12dp"
    android:paddingEnd="12dp"
    android:paddingBottom="12dp">

    <!-- 排名 -->
    <TextView
        android:id="@+id/rankText"
        android:layout_width="28dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="?attr/qmColorTextSecondary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- 标签 + 副标题 + 进度条 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?attr/qmColorTextPrimary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="?attr/qmColorTextSecondary"
            android:textSize="11sp"
            android:visibility="gone" />

        <!-- 相对第一名的进度条 -->
        <ProgressBar
            android:id="@+id/rankProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="6dp"
            android:max="100"
            android:progressDrawable="@drawable/bg_rank_progress" />
    </LinearLayout>

    <!-- 数值 -->
    <TextView
        android:id="@+id/valueText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textColor="?attr/qmColorPrimary"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
