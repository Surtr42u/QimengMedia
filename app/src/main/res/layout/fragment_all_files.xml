<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/allSwipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/qmColorBg"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    tools:context=".ui.all.AllFilesFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="全部"
                android:textColor="?attr/qmColorTextPrimary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/allFilesSummaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="0 文件 · 0 B"
                android:textColor="?attr/qmColorTextSecondary"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/allFilterButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_capsule_soft"
            android:padding="8dp"
            android:src="@drawable/ic_home_filter"
            app:tint="?attr/qmColorPrimary" />

        <ImageView
            android:id="@+id/allColumnText"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_capsule_soft"
            android:padding="8dp"
            android:src="@drawable/ic_home_grid"
            app:tint="?attr/qmColorPrimary" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/allChipAll"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="分区"
                android:textColor="@color/qm_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/allChipSource"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginStart="6dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="作品"
                android:textColor="@color/qm_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/allChipCharacter"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginStart="6dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="角色"
                android:textColor="@color/qm_text_secondary"
                android:textSize="12sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="18dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="?attr/qmColorDivider" />

            <TextView
                android:id="@+id/allChipType"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="类型"
                android:textColor="@color/qm_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </HorizontalScrollView>



    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/allFilesRecycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingBottom="180dp" />

        <com.qimeng.media.ui.widget.MaxHeightScrollView
            android:id="@+id/allPillsScroller"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="vertical"
            android:visibility="gone"
            android:elevation="4dp"
            android:background="?attr/qmColorBg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:id="@+id/allPillsWrapper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </com.qimeng.media.ui.widget.MaxHeightScrollView>
    </FrameLayout>
</LinearLayout>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
