<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/qmColorBg"
    android:orientation="vertical"
    tools:context=".ui.album.AlbumDetailFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp">

        <ImageView
            android:id="@+id/albumDetailBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="9dp"
            android:src="@drawable/ic_detail_back"
            app:tint="?attr/qmColorPrimary"
            android:contentDescription="返回" />

        <TextView
            android:id="@+id/albumDetailTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="相册详情"
            android:textColor="@color/qm_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/albumDetailColumnButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_capsule_soft"
            android:padding="6dp"
            android:src="@drawable/ic_grid_3"
            android:contentDescription="列数" />

        <ImageView
            android:id="@+id/albumDetailFilterButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_capsule_soft"
            android:padding="6dp"
            android:src="@drawable/ic_home_filter"
            app:tint="?attr/qmColorPrimary"
            android:contentDescription="筛选" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/albumDetailChipCharacter"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="角色"
                android:textColor="@color/qm_text_secondary"
                android:textSize="12sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="18dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="?attr/qmColorDivider" />

            <TextView
                android:id="@+id/albumDetailChipType"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="类型"
                android:textColor="@color/qm_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/albumDetailCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="4dp"
        android:textColor="@color/qm_text_secondary"
        android:textSize="13sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/albumDetailRecycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="180dp" />

        <com.qimeng.media.ui.widget.MaxHeightScrollView
            android:id="@+id/albumDetailPillsScroller"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="vertical"
            android:visibility="gone"
            android:elevation="4dp"
            android:background="?attr/qmColorBg"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:id="@+id/albumDetailPillsWrapper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </com.qimeng.media.ui.widget.MaxHeightScrollView>
    </FrameLayout>

    <TextView
        android:id="@+id/albumDetailEmptyText"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="该出处下没有匹配的文件"
        android:textColor="@color/qm_text_secondary"
        android:textSize="14sp"
        android:visibility="gone" />

</LinearLayout>
