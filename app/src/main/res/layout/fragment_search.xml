<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/qmColorSurface"
    android:orientation="vertical">

    <!-- 搜索栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">

        <ImageView
            android:id="@+id/searchBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回" />

        <EditText
            android:id="@+id/searchInput"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_capsule_soft"
            android:hint="搜索文件、出处、角色、COS作者…"
            android:textColorHint="?attr/qmColorTextSecondary"
            android:textColor="?attr/qmColorTextPrimary"
            android:textSize="14sp"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingHorizontal="14dp" />

        <TextView
            android:id="@+id/searchAction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="搜索"
            android:textColor="?attr/qmColorPrimary"
            android:textSize="14sp"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- 状态1：空状态（推荐搜索在上 + 搜索历史在下） -->
    <ScrollView
        android:id="@+id/searchEmptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="12dp">

            <!-- 推荐搜索卡片 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_card"
                android:paddingHorizontal="14dp"
                android:paddingTop="4dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:gravity="center_vertical"
                    android:text="推荐搜索"
                    android:textColor="?attr/qmColorTextSecondary"
                    android:textSize="13sp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/searchRecommendChips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- 搜索历史卡片 -->
            <LinearLayout
                android:id="@+id/searchHistorySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:background="@drawable/bg_stat_card"
                android:paddingHorizontal="14dp"
                android:paddingTop="4dp"
                android:paddingBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="搜索历史"
                        android:textColor="?attr/qmColorTextSecondary"
                        android:textSize="13sp" />

                    <ImageView
                        android:id="@+id/searchHistoryClear"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:padding="4dp"
                        android:src="@drawable/ic_delete_small"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="清除历史" />
                </LinearLayout>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/searchHistoryChips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="4dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 状态2：补全推荐列表（一行一个，从短到长排序） -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/searchSuggestList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="8dp" />

    <!-- 状态3：搜索结果 -->
    <FrameLayout
        android:id="@+id/searchResultState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/searchResultList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="4dp" />

        <TextView
            android:id="@+id/searchEmptyHint"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="未找到相关内容"
            android:textColor="?attr/qmColorTextSecondary"
            android:textSize="14sp"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>
