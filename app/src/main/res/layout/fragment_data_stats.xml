<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/qmColorBg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题区 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="数据统计"
            android:textColor="?attr/qmColorTextPrimary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- 时间范围切换胶囊组 -->
        <LinearLayout
            android:id="@+id/timeRangeContainer"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_capsule_soft"
            android:orientation="horizontal"
            android:padding="3dp">

            <TextView
                android:id="@+id/range7Days"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_capsule_primary"
                android:gravity="center"
                android:text="7天"
                android:textColor="?attr/qmColorBg"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/range30Days"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="30天"
                android:textColor="?attr/qmColorTextSecondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/rangeAll"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="全部"
                android:textColor="?attr/qmColorTextSecondary"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 总览数字卡片 - 第一行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/totalViewsValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="?attr/qmColorPrimary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="总浏览次数"
                    android:textColor="?attr/qmColorTextSecondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/totalPlayValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="?attr/qmColorPrimary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="总播放次数"
                    android:textColor="?attr/qmColorTextSecondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/totalBrowseTimeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0分"
                    android:textColor="?attr/qmColorPrimary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="总浏览时长"
                    android:textColor="?attr/qmColorTextSecondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 总览数字卡片 - 第二行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/totalFilesValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="?attr/qmColorPrimary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="总文件数"
                    android:textColor="?attr/qmColorTextSecondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/totalSizeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="?attr/qmColorPrimary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="总占用空间"
                    android:textColor="?attr/qmColorTextSecondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_card"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/avgBrowseValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="?attr/qmColorPrimary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="平均浏览深度"
                    android:textColor="?attr/qmColorTextSecondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 浏览趋势折线图卡片 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_stat_card"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="浏览趋势"
                android:textColor="?attr/qmColorTextPrimary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.qimeng.media.ui.widget.LineChartView
                android:id="@+id/trendChart"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- 类型 + 来源分布合并卡片（两个环形图横向排列，点击进入分布详情） -->
        <LinearLayout
            android:id="@+id/distributionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_stat_card"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="分布统计"
                    android:textColor="?attr/qmColorTextPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="查看详情 ›"
                    android:textColor="?attr/qmColorPrimary"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="类型分布"
                        android:textColor="?attr/qmColorTextSecondary"
                        android:textSize="12sp" />

                    <com.qimeng.media.ui.widget.PieChartView
                        android:id="@+id/typeDistributionChart"
                        android:layout_width="match_parent"
                        android:layout_height="220dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="来源分布"
                        android:textColor="?attr/qmColorTextSecondary"
                        android:textSize="12sp" />

                    <com.qimeng.media.ui.widget.PieChartView
                        android:id="@+id/sourceDistributionChart"
                        android:layout_width="match_parent"
                        android:layout_height="220dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 热门文件 Top 5 柱状图卡片（点击弹出详细排行榜） -->
        <LinearLayout
            android:id="@+id/topFilesCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_stat_card"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="热门文件 Top 5"
                    android:textColor="?attr/qmColorTextPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="查看全部 ›"
                    android:textColor="?attr/qmColorPrimary"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.qimeng.media.ui.widget.BarChartView
                android:id="@+id/topFilesChart"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- 作者文件数 Top 5 横向柱条卡片（点击弹出详细排行榜） -->
        <LinearLayout
            android:id="@+id/topAuthorsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_stat_card"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="作者文件数 Top 5"
                    android:textColor="?attr/qmColorTextPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="查看全部 ›"
                    android:textColor="?attr/qmColorPrimary"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.qimeng.media.ui.widget.BrowseStatsChartView
                android:id="@+id/topAuthorsChart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- 标签统计 Top 5 横向柱条卡片（点击弹出详细排行榜） -->
        <LinearLayout
            android:id="@+id/topTagsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_stat_card"
            android:clickable="true"
            android:focusable="true"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="标签文件数 Top 5"
                    android:textColor="?attr/qmColorTextPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="查看全部 ›"
                    android:textColor="?attr/qmColorPrimary"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.qimeng.media.ui.widget.BrowseStatsChartView
                android:id="@+id/topTagsChart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
