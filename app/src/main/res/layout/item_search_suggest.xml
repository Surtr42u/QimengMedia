<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="42dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp">

    <ImageView
        android:id="@+id/suggestIcon"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:alpha="0.4"
        android:src="@drawable/ic_search_suggest" />

    <TextView
        android:id="@+id/suggestText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:singleLine="true"
        android:textColor="?attr/qmColorTextPrimary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/suggestTypeLabel"
        android:layout_width="wrap_content"
        android:layout_height="18dp"
        android:layout_marginStart="8dp"
        android:gravity="center"
        android:paddingHorizontal="6dp"
        android:textColor="?attr/qmColorTextSecondary"
        android:textSize="10sp" />
</LinearLayout>
