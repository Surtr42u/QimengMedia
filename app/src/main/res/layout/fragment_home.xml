<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/homeSwipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/qmColorBg"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    tools:context=".ui.main.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:text="首页"
            android:textColor="?attr/qmColorTextPrimary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/homeSearchInput"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_capsule_soft"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingHorizontal="14dp"
            android:singleLine="true"
            android:textColor="?attr/qmColorTextPrimary"
            android:textColorHint="?attr/qmColorTextSecondary"
            android:textSize="13sp" />

        <ImageView
            android:id="@+id/homeFilterButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_capsule_soft"
            android:padding="9dp"
            android:src="@drawable/ic_home_filter"
            app:tint="?attr/qmColorPrimary" />

        <ImageView
            android:id="@+id/homeColumnButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_capsule_soft"
            android:padding="9dp"
            android:src="@drawable/ic_home_grid"
            app:tint="?attr/qmColorPrimary" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/chipRecommend"
            style="@style/QimengCapsuleChip"
            android:background="@drawable/bg_capsule_primary"
            android:text="推荐"
            android:textColor="?attr/qmColorBg" />

        <TextView
            android:id="@+id/chipCos"
            style="@style/QimengCapsuleChip"
            android:text="COS" />

        <TextView
            android:id="@+id/chipRanking"
            style="@style/QimengCapsuleChip"
            android:text="排行榜" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/homeRankPeriodContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/chipRankDay"
            style="@style/QimengCapsuleChip"
            android:text="日榜" />

        <TextView
            android:id="@+id/chipRankWeek"
            style="@style/QimengCapsuleChip"
            android:text="周榜" />

        <TextView
            android:id="@+id/chipRankMonth"
            style="@style/QimengCapsuleChip"
            android:text="月榜" />

        <TextView
            android:id="@+id/chipRankYear"
            style="@style/QimengCapsuleChip"
            android:text="年榜" />
    </LinearLayout>



    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/homeRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1" />
</LinearLayout>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
